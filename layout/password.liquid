<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#8795d2">

  <title>{{ shop.name }} — Coming soon</title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    @font-face {
      font-family: 'Friendship';
      src: url('{{ 'Friendship-Medium.otf' | asset_url }}') format('opentype');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Farmhouse';
      src: url('{{ 'Farmhouse.otf' | asset_url }}') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink-900: #1a1a1a;
      --ink-700: #3d3d3d;
      --ink-400: #888;
      --periwinkle: #8795d2;
      --cream: #faf8f4;
      --sand: #f0ece4;
    }

    body {
      font-family: 'Hanken Grotesk', sans-serif;
      background: var(--cream);
      color: var(--ink-900);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
    }

    .pw-logo {
      width: 120px;
      margin-bottom: 32px;
    }

    h1 {
      font-family: 'Farmhouse', serif;
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
      text-align: center;
    }

    .pw-lead {
      color: var(--ink-700);
      font-size: 17px;
      max-width: 420px;
      text-align: center;
      line-height: 1.6;
      margin-bottom: 36px;
    }

    .pw-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      width: 100%;
      max-width: 340px;
    }

    .pw-form input[type="password"] {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid var(--sand);
      border-radius: 8px;
      font-family: inherit;
      font-size: 15px;
      background: #fff;
      outline: none;
      transition: border-color 0.15s;
    }

    .pw-form input[type="password"]:focus {
      border-color: var(--periwinkle);
    }

    .pw-btn {
      padding: 13px 24px;
      background: var(--ink-900);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: opacity 0.15s;
    }

    .pw-btn:hover { opacity: 0.85; }

    .pw-error {
      color: #c0392b;
      font-size: 14px;
      text-align: center;
    }

    .pw-footer {
      margin-top: 48px;
      color: var(--ink-400);
      font-size: 13px;
    }
  </style>
</head>

<body>
  <img class="pw-logo" src="{{ 'kyn-logo.png' | asset_url }}" alt="{{ shop.name }}">

  <h1>Pronto estamos aquí.</h1>
  <p class="pw-lead">Gear up for the good walks — handmade biothane &amp; solid brass. Muy pronto en línea.</p>

  {% form 'storefront_password' %}
    <div class="pw-form">
      {{ form.errors | default_errors }}
      <input
        type="password"
        name="password"
        id="password"
        placeholder="Contraseña"
        autocomplete="current-password"
        autofocus
      >
      <button type="submit" class="pw-btn">Entrar</button>
    </div>
  {% endform %}

  <p class="pw-footer">{{ shop.name }}</p>

  {{ content_for_layout }}
</body>
</html>
