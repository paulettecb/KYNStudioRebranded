<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#FBFAF7">
  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  {% if settings.favicon != blank %}<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">{% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300..800&display=swap">
  <style>
    @font-face { font-family: 'Friendship'; src: url('{{ 'Friendship-Medium.otf' | asset_url }}') format('opentype'); font-weight: 500; font-style: normal; font-display: swap; }
    @font-face { font-family: 'Farmhouse';  src: url('{{ 'Farmhouse.otf' | asset_url }}') format('opentype');  font-weight: 400; font-style: normal; font-display: swap; }
  </style>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js" defer></script>

  {{ content_for_header }}
</head>
<body class="template-{{ template.name }}">
  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (window.lucide) window.lucide.createIcons({ attrs: { 'stroke-width': 1.75 } });
    });
  </script>
</body>
</html>
