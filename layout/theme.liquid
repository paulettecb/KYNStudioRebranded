<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#8795d2">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged {{ current_tags | join: ', ' }}{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- assign kyn_social_image = settings.social_share_image -%}
  {%- if kyn_social_image != blank -%}
    <meta property="og:image" content="{{ kyn_social_image | image_url: width: 1200 }}">
    <meta name="twitter:image" content="{{ kyn_social_image | image_url: width: 1200 }}">
  {%- else -%}
    <meta property="og:image" content="{{ 'kyn-preview.svg' | asset_url }}">
    <meta name="twitter:image" content="{{ 'kyn-preview.svg' | asset_url }}">
  {%- endif -%}
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:site_name" content="{{ shop.name | escape }}">
  <meta name="twitter:card" content="summary_large_image">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/png" href="{{ 'kyn-logo.png' | asset_url }}">
  {%- endif -%}

  {{ content_for_header }}

  <!-- KYN: Hanken Grotesk from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- KYN: Custom fonts -->
  <style>
    @font-face {
      font-family: 'Friendship';
      src: url('{{ 'Friendship-Medium.otf' | asset_url }}') format('opentype');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Farmhouse';
      src: url('{{ 'Farmhouse.otf' | asset_url }}') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if template.name == 'product' -%}
    {{ 'kyn-pdp.css' | asset_url | stylesheet_tag }}
  {%- endif -%}
</head>

<body class="template-{{ template.name }}{% if template.suffix != blank %}-{{ template.suffix }}{% endif %}">

  {%- sections 'header-group' -%}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

</body>
</html>
