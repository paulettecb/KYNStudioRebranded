{%- capture text_font -%}{% render 'font-stack', key: section.settings.text_font %}{%- endcapture -%}

{%- if section.blocks.size > 0 -%}
<div id="announcement-bar-{{ section.id }}" class="announcement" role="region" aria-label="Announcements">
  {%- for block in section.blocks -%}
    <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
    {%- unless forloop.last -%}<span class="sep">·</span>{%- endunless -%}
  {%- endfor -%}
</div>
{%- endif -%}

<style>
  #announcement-bar-{{ section.id }}.announcement{
    font-family: {{ text_font }};
    font-size: {{ section.settings.text_size }}px;
  }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 4,
  "settings": [
    { "type": "header", "content": "Message text" },
    { "type": "select", "id": "text_font", "label": "Message font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "text_size", "label": "Message size", "min": 10, "max": 22, "step": 1, "unit": "px", "default": 13 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Message",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p><strong>Free shipping over $60</strong></p>" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "text": "<p><strong>Free shipping over $60</strong></p>" } },
      { "type": "item", "settings": { "text": "<p>One-year warranty</p>" } },
      { "type": "item", "settings": { "text": "<p><strong>New drop:</strong> the Blush Collar is here</p>" } }
    ]
  }
}
{% endschema %}
