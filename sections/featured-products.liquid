{%- assign heading = section.settings.heading -%}
{%- assign spark = section.settings.spark_word -%}
{%- if spark != blank -%}
  {%- capture spark_html -%}<span class="spark">{{ spark }}</span>{%- endcapture -%}
  {%- assign heading = heading | replace: spark, spark_html -%}
{%- endif -%}

<section class="section featured-products">
  <div class="container">
    <div class="sec-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ heading }}</h2>
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a class="kyn-btn kyn-btn--ghost kyn-btn--sm" href="{{ section.settings.cta_link | default: '#' }}">{{ section.settings.cta_label }} {% render 'icon', name: 'arrow-right' %}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- assign source = collections[section.settings.collection] -%}
      {%- if source.products_count > 0 -%}
        {%- for product in source.products limit: section.settings.product_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {% render 'product-card', product: nil, placeholder_label: 'Waterproof Collar' %}
        {% render 'product-card', product: nil, placeholder_label: 'Waterproof Leash' %}
        {% render 'product-card', product: nil, placeholder_label: 'Walk Set' %}
        {% render 'product-card', product: nil, placeholder_label: 'Brass Charms' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The pieces our pack loves most." },
    { "type": "text", "id": "spark_word", "label": "Spark word", "default": "loves" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "header", "content": "View-all link" },
    { "type": "text", "id": "cta_label", "label": "Link label", "default": "View all" },
    { "type": "url",  "id": "cta_link",  "label": "Link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
