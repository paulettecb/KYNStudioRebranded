<section class="section" style="text-align:center;">
  <div class="container">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 style="font-size:72px;margin:18px 0;">{{ section.settings.heading }}</h1>
    <p style="color:var(--ink-700);font-size:18px;max-width:480px;margin:0 auto 28px;">{{ section.settings.text }}</p>
    <a class="kyn-btn kyn-btn--primary kyn-btn--lg" href="{{ section.settings.button_link | default: routes.root_url }}">{{ section.settings.button_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "404" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Lost on the trail." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "The page you're looking for has wandered off. Let's get you back to the pack." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Back to home" },
    { "type": "url", "id": "button_link", "label": "Button link", "info": "Defaults to the homepage" }
  ],
  "presets": [{ "name": "404" }]
}
{% endschema %}
