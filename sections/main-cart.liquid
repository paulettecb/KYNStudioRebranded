{%- capture title_font -%}{% render 'font-stack', key: section.settings.title_font %}{%- endcapture -%}
{%- capture empty_message_font -%}{% render 'font-stack', key: section.settings.empty_message_font %}{%- endcapture -%}
{%- capture item_variant_font -%}{% render 'font-stack', key: section.settings.item_variant_font %}{%- endcapture -%}
{%- capture shipping_note_font -%}{% render 'font-stack', key: section.settings.shipping_note_font %}{%- endcapture -%}
{%- capture totals_font -%}{% render 'font-stack', key: section.settings.totals_font %}{%- endcapture -%}

<section class="section" id="main-cart-{{ section.id }}">
  <div class="container">
    <h1 class="section__title">{{ section.settings.title }}</h1>

    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:60px 0;">
        <p class="cart-empty__message" style="color:var(--ink-700);margin-bottom:24px;">{{ section.settings.empty_message }}</p>
        <a class="kyn-btn kyn-btn--primary" href="{{ routes.root_url }}">{{ section.settings.continue_shopping_label }}</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy">
                {%- endif -%}
              </a>
              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                {%- for property in item.properties -%}
                  {%- unless property.last == blank -%}
                    <p class="cart-item__property"><em>{{ property.first }}:</em> {{ property.last }}</p>
                  {%- endunless -%}
                {%- endfor -%}
                <div class="cart-item__row">
                  <div class="cart-qty">
                    <button type="button" class="cart-qty__btn" data-action="minus" data-line="{{ forloop.index }}">−</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      class="cart-qty__input"
                      data-line="{{ forloop.index }}"
                    >
                    <button type="button" class="cart-qty__btn" data-action="plus" data-line="{{ forloop.index }}">+</button>
                  </div>
                  <span class="cart-item__price">{{ item.final_line_price | money }}</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-footer">
          <div class="cart-totals">
            <span>Subtotal</span>
            <span class="cart-totals__price">{{ cart.total_price | money }}</span>
          </div>
          {%- if section.settings.show_shipping_note -%}
            <p class="cart-shipping-note" style="color:var(--ink-400);margin-bottom:20px;">{{ section.settings.shipping_note }}</p>
          {%- endif -%}
          <button type="submit" name="checkout" class="kyn-btn kyn-btn--primary kyn-btn--lg" style="width:100%;">
            {{ section.settings.checkout_label }}
          </button>
          <a href="{{ routes.root_url }}" class="kyn-btn kyn-btn--ghost kyn-btn--sm" style="width:100%;margin-top:10px;text-align:center;">
            {{ section.settings.continue_shopping_label }}
          </a>
        </div>

        <input type="hidden" name="return_to" value="/cart">
      </form>

      <script>
      (function () {
        document.querySelectorAll('.cart-qty__btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var line  = this.dataset.line;
            var input = document.querySelector('.cart-qty__input[data-line="' + line + '"]');
            if (!input) return;
            var val = parseInt(input.value, 10) || 0;
            input.value = this.dataset.action === 'plus' ? val + 1 : Math.max(0, val - 1);
          });
        });
      }());
      </script>
    {%- endif -%}
  </div>
</section>

<style>
.section__title { margin-bottom: 32px; }
.cart-items { display: flex; flex-direction: column; gap: 24px; margin-bottom: 32px; }
.cart-item { display: flex; gap: 20px; padding-bottom: 24px; border-bottom: 1px solid var(--sand, #f0ece4); }
.cart-item img { border-radius: 8px; object-fit: cover; width: 80px; height: 80px; flex-shrink: 0; }
.cart-item__info { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.cart-item__title { font-weight: 600; text-decoration: none; color: inherit; }
.cart-item__variant, .cart-item__property { color: var(--ink-400, #888); }
.cart-item__row { display: flex; align-items: center; gap: 16px; margin-top: auto; }
.cart-qty { display: flex; align-items: center; border: 1.5px solid var(--sand, #f0ece4); border-radius: 6px; overflow: hidden; }
.cart-qty__btn { background: none; border: none; width: 32px; height: 36px; font-size: 18px; cursor: pointer; }
.cart-qty__input { width: 44px; border: none; text-align: center; font-family: inherit; font-size: 14px; -moz-appearance: textfield; }
.cart-qty__input::-webkit-inner-spin-button, .cart-qty__input::-webkit-outer-spin-button { display: none; }
.cart-item__price { font-weight: 600; margin-left: auto; }
.cart-footer { max-width: 400px; margin-left: auto; }
.cart-totals { display: flex; justify-content: space-between; font-weight: 600; margin-bottom: 8px; }

#main-cart-{{ section.id }} .section__title{
  font-family: {{ title_font }};
  font-size: {{ section.settings.title_size }}px;
}
#main-cart-{{ section.id }} .cart-empty__message{
  font-family: {{ empty_message_font }};
  font-size: {{ section.settings.empty_message_size }}px;
}
#main-cart-{{ section.id }} .cart-item__variant,
#main-cart-{{ section.id }} .cart-item__property{
  font-family: {{ item_variant_font }};
  font-size: {{ section.settings.item_variant_size }}px;
}
#main-cart-{{ section.id }} .cart-shipping-note{
  font-family: {{ shipping_note_font }};
  font-size: {{ section.settings.shipping_note_size }}px;
}
#main-cart-{{ section.id }} .cart-totals{
  font-family: {{ totals_font }};
  font-size: {{ section.settings.totals_size }}px;
}
@media (max-width: 749px){
  #main-cart-{{ section.id }} .section__title{ font-size: {{ section.settings.title_size | times: 0.61 | round }}px; }
}
</style>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "header", "content": "Title" },
    { "type": "text", "id": "title", "label": "Title", "default": "Tu carrito" },
    { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 20, "max": 48, "step": 2, "unit": "px", "default": 36 },

    { "type": "header", "content": "Empty cart" },
    { "type": "text", "id": "empty_message", "label": "Empty cart message", "default": "Tu carrito está vacío." },
    { "type": "select", "id": "empty_message_font", "label": "Empty cart message font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "empty_message_size", "label": "Empty cart message size", "min": 14, "max": 28, "step": 1, "unit": "px", "default": 18 },

    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "continue_shopping_label", "label": "Continue shopping button label", "default": "Seguir comprando" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Finalizar compra" },

    { "type": "header", "content": "Line item text" },
    { "type": "select", "id": "item_variant_font", "label": "Variant / property text font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "item_variant_size", "label": "Variant / property text size", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Shipping note" },
    { "type": "checkbox", "id": "show_shipping_note", "label": "Show shipping/taxes note", "default": true },
    { "type": "text", "id": "shipping_note", "label": "Shipping/taxes note", "default": "Impuestos y envío calculados al finalizar la compra." },
    { "type": "select", "id": "shipping_note_font", "label": "Shipping note font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "shipping_note_size", "label": "Shipping note size", "min": 11, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Cart totals" },
    { "type": "select", "id": "totals_font", "label": "Cart totals font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "totals_size", "label": "Cart totals size", "min": 14, "max": 28, "step": 1, "unit": "px", "default": 18 }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
