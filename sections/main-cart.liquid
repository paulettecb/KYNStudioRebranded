<section class="section">
  <div class="container">
    <h1 class="section__title">Tu carrito</h1>

    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:60px 0;">
        <p style="color:var(--ink-700);font-size:18px;margin-bottom:24px;">Tu carrito está vacío.</p>
        <a class="kyn-btn kyn-btn--primary" href="{{ routes.root_url }}">Seguir comprando</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy">
                {%- endif -%}
              </a>
              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                {%- for property in item.properties -%}
                  {%- unless property.last == blank -%}
                    <p class="cart-item__property"><em>{{ property.first }}:</em> {{ property.last }}</p>
                  {%- endunless -%}
                {%- endfor -%}
                <div class="cart-item__row">
                  <div class="cart-qty">
                    <button type="button" class="cart-qty__btn" data-action="minus" data-line="{{ forloop.index }}">−</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      class="cart-qty__input"
                      data-line="{{ forloop.index }}"
                    >
                    <button type="button" class="cart-qty__btn" data-action="plus" data-line="{{ forloop.index }}">+</button>
                  </div>
                  <span class="cart-item__price">{{ item.final_line_price | money }}</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-footer">
          <div class="cart-totals">
            <span>Subtotal</span>
            <span class="cart-totals__price">{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size:13px;color:var(--ink-400);margin-bottom:20px;">Impuestos y envío calculados al finalizar la compra.</p>
          <button type="submit" name="checkout" class="kyn-btn kyn-btn--primary kyn-btn--lg" style="width:100%;">
            Finalizar compra
          </button>
          <a href="{{ routes.root_url }}" class="kyn-btn kyn-btn--ghost kyn-btn--sm" style="width:100%;margin-top:10px;text-align:center;">
            Seguir comprando
          </a>
        </div>

        <input type="hidden" name="return_to" value="/cart">
      </form>

      <script>
      (function () {
        document.querySelectorAll('.cart-qty__btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var line  = this.dataset.line;
            var input = document.querySelector('.cart-qty__input[data-line="' + line + '"]');
            if (!input) return;
            var val = parseInt(input.value, 10) || 0;
            input.value = this.dataset.action === 'plus' ? val + 1 : Math.max(0, val - 1);
          });
        });
      }());
      </script>
    {%- endif -%}
  </div>
</section>

<style>
.section__title { font-size: clamp(22px,4vw,36px); margin-bottom: 32px; }
.cart-items { display: flex; flex-direction: column; gap: 24px; margin-bottom: 32px; }
.cart-item { display: flex; gap: 20px; padding-bottom: 24px; border-bottom: 1px solid var(--sand, #f0ece4); }
.cart-item img { border-radius: 8px; object-fit: cover; width: 80px; height: 80px; flex-shrink: 0; }
.cart-item__info { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.cart-item__title { font-weight: 600; text-decoration: none; color: inherit; }
.cart-item__variant, .cart-item__property { font-size: 13px; color: var(--ink-400, #888); }
.cart-item__row { display: flex; align-items: center; gap: 16px; margin-top: auto; }
.cart-qty { display: flex; align-items: center; border: 1.5px solid var(--sand, #f0ece4); border-radius: 6px; overflow: hidden; }
.cart-qty__btn { background: none; border: none; width: 32px; height: 36px; font-size: 18px; cursor: pointer; }
.cart-qty__input { width: 44px; border: none; text-align: center; font-family: inherit; font-size: 14px; -moz-appearance: textfield; }
.cart-qty__input::-webkit-inner-spin-button, .cart-qty__input::-webkit-outer-spin-button { display: none; }
.cart-item__price { font-weight: 600; margin-left: auto; }
.cart-footer { max-width: 400px; margin-left: auto; }
.cart-totals { display: flex; justify-content: space-between; font-size: 18px; font-weight: 600; margin-bottom: 8px; }
</style>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
