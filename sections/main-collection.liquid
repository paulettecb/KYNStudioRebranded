{%- paginate collection.products by section.settings.products_per_page -%}

<section class="section">
  <div class="container">
    <div class="collection-header">
      {%- if collection.image -%}
        <div class="collection-banner">
          <img src="{{ collection.image | image_url: width: 1400 }}" alt="{{ collection.title | escape }}" width="1400" height="400" loading="eager">
          <div class="collection-banner__overlay">
            <h1>{{ collection.title }}</h1>
          </div>
        </div>
      {%- else -%}
        <h1>{{ collection.title }}</h1>
      {%- endif -%}
      {%- if section.settings.show_description and collection.description != blank -%}
        <p class="collection-desc">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p style="color:var(--ink-400);">{{ section.settings.empty_message }}</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  </div>
</section>

{%- endpaginate -%}

<style>
.collection-header { margin-bottom: 40px; }
.collection-banner { position: relative; border-radius: 12px; overflow: hidden; margin-bottom: 20px; }
.collection-banner img { width: 100%; height: 320px; object-fit: cover; display: block; }
.collection-banner__overlay { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: 32px; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%); }
.collection-banner__overlay h1 { color: #fff; font-size: clamp(28px,5vw,48px); }
.collection-desc { color: var(--ink-700, #3d3d3d); max-width: 640px; line-height: 1.6; }
.pagination { text-align: center; margin-top: 48px; }
</style>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "text", "id": "empty_message", "label": "Empty collection message", "default": "No hay productos en esta colección todavía." }
  ],
  "presets": [{ "name": "Collection" }]
}
{% endschema %}
