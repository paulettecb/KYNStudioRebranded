{%- comment -%}
  KYN — Newsletter signup section
{%- endcomment -%}

{%- capture eyebrow_font -%}{% render 'font-stack', key: section.settings.eyebrow_font %}{%- endcapture -%}
{%- capture title_font -%}{% render 'font-stack', key: section.settings.title_font %}{%- endcapture -%}
{%- capture spark_font -%}{% render 'font-stack', key: section.settings.spark_font %}{%- endcapture -%}
{%- capture lead_font -%}{% render 'font-stack', key: section.settings.lead_font %}{%- endcapture -%}
{%- capture placeholder_font -%}{% render 'font-stack', key: section.settings.placeholder_font %}{%- endcapture -%}
{%- capture button_font -%}{% render 'font-stack', key: section.settings.button_font %}{%- endcapture -%}
{%- capture success_font -%}{% render 'font-stack', key: section.settings.success_font %}{%- endcapture -%}
{%- capture fineprint_font -%}{% render 'font-stack', key: section.settings.fineprint_font %}{%- endcapture -%}

<section id="newsletter-{{ section.id }}" class="section newsletter" style="background: {{ section.settings.bg }};">
  <div class="container">
    <div class="newsletter__card">
      <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
      <h2 class="h-display">
        {{ section.settings.title | escape }}
        {%- if section.settings.spark_word != blank -%}
          <span class="spark">{{ section.settings.spark_word | escape }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.lead != blank -%}
        <p class="lead">{{ section.settings.lead | escape }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="newsletter-email">Email</label>
        <input id="newsletter-email"
               type="email"
               name="contact[email]"
               placeholder="{{ section.settings.placeholder | escape }}"
               autocomplete="email"
               required>
        <button type="submit" class="btn btn--primary">{{ section.settings.button | escape }}</button>
        {%- if form.posted_successfully? -%}
          <p class="newsletter__success">{{ section.settings.success | escape }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="newsletter__error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.fineprint != blank -%}
        <small class="newsletter__fineprint">{{ section.settings.fineprint | escape }}</small>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #newsletter-{{ section.id }} .eyebrow{
    font-family: {{ eyebrow_font }};
    font-size: {{ section.settings.eyebrow_size }}px;
  }
  #newsletter-{{ section.id }} .h-display{
    font-family: {{ title_font }};
    font-size: {{ section.settings.title_size }}px;
  }
  #newsletter-{{ section.id }} .h-display .spark{
    font-family: {{ spark_font }};
    font-size: {{ section.settings.spark_size }}px;
  }
  #newsletter-{{ section.id }} .lead{
    font-family: {{ lead_font }};
    font-size: {{ section.settings.lead_size }}px;
  }
  #newsletter-{{ section.id }} .newsletter__form input[type=email]{
    font-family: {{ placeholder_font }};
    font-size: {{ section.settings.placeholder_size }}px;
  }
  #newsletter-{{ section.id }} .newsletter__form .btn{
    font-family: {{ button_font }};
    font-size: {{ section.settings.button_size }}px;
  }
  #newsletter-{{ section.id }} .newsletter__success{
    font-family: {{ success_font }};
    font-size: {{ section.settings.success_size }}px;
  }
  #newsletter-{{ section.id }} .newsletter__fineprint{
    font-family: {{ fineprint_font }};
    font-size: {{ section.settings.fineprint_size }}px;
  }
  @media (max-width: 749px){
    #newsletter-{{ section.id }} .h-display{ font-size: {{ section.settings.title_size | times: 0.72 | round }}px; }
    #newsletter-{{ section.id }} .h-display .spark{ font-size: {{ section.settings.spark_size | times: 0.72 | round }}px; }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#E5E9F4" },

    { "type": "header", "content": "Eyebrow" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "Más que amigos del parque" },
    { "type": "select", "id": "eyebrow_font", "label": "Eyebrow font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Title" },
    { "type": "text",  "id": "title", "label": "Title", "default": "Lanzamientos, colores y cosas" },
    { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 24, "max": 72, "step": 2, "unit": "px", "default": 40 },
    { "type": "text",  "id": "spark_word", "label": "Spark word", "default": "lindas." },
    { "type": "select", "id": "spark_font", "label": "Spark word font", "default": "display",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "spark_size", "label": "Spark word size", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Lead text" },
    { "type": "text",  "id": "lead", "label": "Lead", "default": "Sé la primera en saber cuándo soltamos un color nuevo o un drop limitado." },
    { "type": "select", "id": "lead_font", "label": "Lead font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "lead_size", "label": "Lead size", "min": 14, "max": 26, "step": 1, "unit": "px", "default": 17 },

    { "type": "header", "content": "Form" },
    { "type": "text",  "id": "placeholder", "label": "Placeholder", "default": "tu correo" },
    { "type": "select", "id": "placeholder_font", "label": "Placeholder font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "placeholder_size", "label": "Placeholder size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 15 },
    { "type": "text",  "id": "button", "label": "Button label", "default": "Suscribirme" },
    { "type": "select", "id": "button_font", "label": "Button font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "button_size", "label": "Button size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 15 },

    { "type": "header", "content": "Success message" },
    { "type": "text",  "id": "success", "label": "Success message", "default": "¡Bienvenida a la manada! 🐾" },
    { "type": "select", "id": "success_font", "label": "Success message font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "success_size", "label": "Success message size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },

    { "type": "header", "content": "Fine print" },
    { "type": "text",  "id": "fineprint", "label": "Fine print", "default": "Sin spam. Solo cosas buenas." },
    { "type": "select", "id": "fineprint_font", "label": "Fine print font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "fineprint_size", "label": "Fine print size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
