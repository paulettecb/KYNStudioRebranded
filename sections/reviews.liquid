{%- comment -%}
  KYN — Reviews / testimonials section
{%- endcomment -%}

{%- capture eyebrow_font -%}{% render 'font-stack', key: section.settings.eyebrow_font %}{%- endcapture -%}
{%- capture title_font -%}{% render 'font-stack', key: section.settings.title_font %}{%- endcapture -%}
{%- capture spark_font -%}{% render 'font-stack', key: section.settings.spark_font %}{%- endcapture -%}

<section id="reviews-{{ section.id }}" class="section reviews" style="background: {{ section.settings.bg }};">
  <div class="container">
    <header class="reviews__head">
      <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
      <h2 class="h-display">
        {{ section.settings.title | escape }}
        {%- if section.settings.spark_word != blank -%}
          <span class="spark">{{ section.settings.spark_word | escape }}</span>
        {%- endif -%}
      </h2>
    </header>

    <div class="reviews__grid">
      {%- for block in section.blocks -%}
        {%- capture quote_font -%}{% render 'font-stack', key: block.settings.quote_font %}{%- endcapture -%}
        {%- capture name_font -%}{% render 'font-stack', key: block.settings.name_font %}{%- endcapture -%}
        {%- capture dog_font -%}{% render 'font-stack', key: block.settings.dog_font %}{%- endcapture -%}
        <figure class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars" aria-label="{{ block.settings.stars }} stars">
            {%- for i in (1..block.settings.stars) -%}★{%- endfor -%}
          </div>
          <blockquote class="review-card__quote" style="font-family: {{ quote_font }}; font-size: {{ block.settings.quote_size }}px;">
            {{ block.settings.quote | escape }}
          </blockquote>
          <figcaption class="review-card__author">
            {%- if block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="" width="40" height="40" loading="lazy">
            {%- endif -%}
            <div>
              <strong style="font-family: {{ name_font }}; font-size: {{ block.settings.name_size }}px;">{{ block.settings.name | escape }}</strong>
              {%- if block.settings.dog != blank -%}
                <span style="font-family: {{ dog_font }}; font-size: {{ block.settings.dog_size }}px;">&amp; {{ block.settings.dog | escape }}</span>
              {%- endif -%}
            </div>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #reviews-{{ section.id }} .eyebrow{
    font-family: {{ eyebrow_font }};
    font-size: {{ section.settings.eyebrow_size }}px;
  }
  #reviews-{{ section.id }} .h-display{
    font-family: {{ title_font }};
    font-size: {{ section.settings.title_size }}px;
  }
  #reviews-{{ section.id }} .h-display .spark{
    font-family: {{ spark_font }};
    font-size: {{ section.settings.spark_size }}px;
  }
  @media (max-width: 749px){
    #reviews-{{ section.id }} .h-display{ font-size: {{ section.settings.title_size | times: 0.72 | round }}px; }
    #reviews-{{ section.id }} .h-display .spark{ font-size: {{ section.settings.spark_size | times: 0.72 | round }}px; }
  }
</style>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#F4F0E8" },

    { "type": "header", "content": "Eyebrow" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "Loved by their humans" },
    { "type": "select", "id": "eyebrow_font", "label": "Eyebrow font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Title" },
    { "type": "text",  "id": "title", "label": "Title", "default": "Real walks, real" },
    { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 24, "max": 72, "step": 2, "unit": "px", "default": 40 },
    { "type": "text",  "id": "spark_word", "label": "Spark word", "default": "tails." },
    { "type": "select", "id": "spark_font", "label": "Spark word font", "default": "display",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "spark_size", "label": "Spark word size", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },

        { "type": "header", "content": "Quote" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Pasamos del clásico collar que se decoloraba al baño, a uno KYN que sigue intacto después de meses. El latón pesa lo justo. Vale cada peso." },
        { "type": "select", "id": "quote_font", "label": "Quote font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "quote_size", "label": "Quote size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },

        { "type": "header", "content": "Author" },
        { "type": "text", "id": "name", "label": "Name", "default": "Andrea M." },
        { "type": "select", "id": "name_font", "label": "Name font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "name_size", "label": "Name size", "min": 10, "max": 22, "step": 1, "unit": "px", "default": 14 },
        { "type": "text", "id": "dog", "label": "Dog's name", "default": "Luna" },
        { "type": "select", "id": "dog_font", "label": "Dog's name font", "default": "accent",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "dog_size", "label": "Dog's name size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },

        { "type": "image_picker", "id": "avatar", "label": "Avatar (optional)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "name": "Andrea M.", "dog": "Luna" } },
        { "type": "review", "settings": { "name": "Diego R.", "dog": "Maple", "quote": "La calidad del biothane es notoria desde que abres la caja. Mi perra ama el paseo y yo amo cómo se ve." } },
        { "type": "review", "settings": { "name": "Sofía P.", "dog": "Bruno", "quote": "Ya tengo 3 collares de KYN. La paleta de colores está hermosa y el hardware nunca falla. Premium real." } }
      ]
    }
  ]
}
{% endschema %}
