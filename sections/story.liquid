{%- comment -%}
  KYN — Brand story section (image + text, alternating layout)
{%- endcomment -%}

{%- capture eyebrow_font -%}{% render 'font-stack', key: section.settings.eyebrow_font %}{%- endcapture -%}
{%- capture title_font -%}{% render 'font-stack', key: section.settings.title_font %}{%- endcapture -%}
{%- capture spark_font -%}{% render 'font-stack', key: section.settings.spark_font %}{%- endcapture -%}
{%- capture body_font -%}{% render 'font-stack', key: section.settings.body_font %}{%- endcapture -%}
{%- capture cta_label_font -%}{% render 'font-stack', key: section.settings.cta_label_font %}{%- endcapture -%}

<section id="story-{{ section.id }}" class="section story" style="background: {{ section.settings.bg }};">
  <div class="container">
    <div class="story__grid {% if section.settings.image_right %}story__grid--reverse{% endif %}">
      <div class="story__media{% if section.settings.video_1 != blank and section.settings.video_2 != blank %} story__media--duo{% endif %}">
        {%- if section.settings.video_1 != blank -%}
          {{ section.settings.video_1 | video_tag: autoplay: true, loop: true, muted: true, class: 'story__video' }}
          {%- if section.settings.video_2 != blank -%}
            {{ section.settings.video_2 | video_tag: autoplay: true, loop: true, muted: true, class: 'story__video' }}
          {%- endif -%}
        {%- elsif section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}"
               srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                       {{ section.settings.image | image_url: width: 1200 }} 1200w"
               sizes="(min-width: 900px) 50vw, 100vw"
               alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
               loading="lazy" width="1200" height="1500">
        {%- else -%}
          <div class="story__media-placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}</div>
        {%- endif -%}
      </div>

      <div class="story__body">
        <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
        <h2 class="h-display">
          {{ section.settings.title | escape }}
          {%- if section.settings.spark_word != blank -%}
            <span class="spark">{{ section.settings.spark_word | escape }}</span>
          {%- endif -%}
        </h2>
        <div class="story__text rte">
          {{ section.settings.body }}
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="story__pillars">
            {%- for block in section.blocks -%}
              {%- capture pillar_title_font -%}{% render 'font-stack', key: block.settings.title_font %}{%- endcapture -%}
              {%- capture pillar_text_font -%}{% render 'font-stack', key: block.settings.text_font %}{%- endcapture -%}
              <li {{ block.shopify_attributes }}>
                {%- if block.settings.icon != 'none' -%}
                  {% render 'icon', name: block.settings.icon %}
                {%- endif -%}
                <div>
                  <strong style="font-family: {{ pillar_title_font }}; font-size: {{ block.settings.title_size }}px;">{{ block.settings.title | escape }}</strong>
                  <span style="font-family: {{ pillar_text_font }}; font-size: {{ block.settings.text_size }}px;">{{ block.settings.text | escape }}</span>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a class="btn btn--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #story-{{ section.id }} .eyebrow{
    font-family: {{ eyebrow_font }};
    font-size: {{ section.settings.eyebrow_size }}px;
  }
  #story-{{ section.id }} .h-display{
    font-family: {{ title_font }};
    font-size: {{ section.settings.title_size }}px;
  }
  #story-{{ section.id }} .h-display .spark{
    font-family: {{ spark_font }};
    font-size: {{ section.settings.spark_size }}px;
  }
  #story-{{ section.id }} .story__text{
    font-family: {{ body_font }};
    font-size: {{ section.settings.body_size }}px;
  }
  #story-{{ section.id }} .btn{
    font-family: {{ cta_label_font }};
    font-size: {{ section.settings.cta_label_size }}px;
  }
  @media (max-width: 749px){
    #story-{{ section.id }} .h-display{ font-size: {{ section.settings.title_size | times: 0.73 | round }}px; }
    #story-{{ section.id }} .h-display .spark{ font-size: {{ section.settings.spark_size | times: 0.73 | round }}px; }
  }
</style>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#FFFDF8" },
    { "type": "checkbox", "id": "image_right", "label": "Image on right", "default": false },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "video", "id": "video_1", "label": "Video (overrides image above if set)" },
    { "type": "video", "id": "video_2", "label": "Video 2 (optional — pairs side-by-side with Video)" },

    { "type": "header", "content": "Eyebrow" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "Hecho a mano" },
    { "type": "select", "id": "eyebrow_font", "label": "Eyebrow font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Title" },
    { "type": "text",  "id": "title", "label": "Title", "default": "Built by hand, made to" },
    { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 24, "max": 72, "step": 2, "unit": "px", "default": 40 },
    { "type": "text",  "id": "spark_word", "label": "Spark word", "default": "last." },
    { "type": "select", "id": "spark_font", "label": "Spark word font", "default": "display",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "spark_size", "label": "Spark word size", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 },

    { "type": "header", "content": "Body text" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Cada collar y correa de KYN se corta, perfora y remacha a mano con biothane original y latón sólido. No es producción en masa — es una pieza para la vida de tu perro.</p>" },
    { "type": "select", "id": "body_font", "label": "Body font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "body_size", "label": "Body size", "min": 14, "max": 26, "step": 1, "unit": "px", "default": 17 },

    { "type": "header", "content": "Button" },
    { "type": "text",  "id": "cta_label", "label": "Button label", "default": "Conoce la historia" },
    { "type": "select", "id": "cta_label_font", "label": "Button font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "cta_label_size", "label": "Button size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 15 },
    { "type": "url",   "id": "cta_link",  "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "paw", "label": "Paw" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "sparkle"
        },
        { "type": "header", "content": "Title" },
        { "type": "text", "id": "title", "label": "Title", "default": "Biothane original" },
        { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "title_size", "label": "Title size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 15 },
        { "type": "header", "content": "Description" },
        { "type": "text", "id": "text", "label": "Text", "default": "Resistente al agua y al barro." },
        { "type": "select", "id": "text_font", "label": "Description font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "text_size", "label": "Description size", "min": 12, "max": 20, "step": 1, "unit": "px", "default": 14 }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Brand story",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "sparkle", "title": "Biothane original", "text": "Resistente al agua y al barro." } },
        { "type": "pillar", "settings": { "icon": "shield", "title": "Latón sólido", "text": "Hardware que no se oxida." } },
        { "type": "pillar", "settings": { "icon": "heart", "title": "Hecho a mano", "text": "En lotes pequeños, con tiempo." } }
      ]
    }
  ]
}
{% endschema %}
