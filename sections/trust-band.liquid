<section class="trust-band">
  <div class="trust-band__row">
    {%- for block in section.blocks -%}
      {%- capture block_title_font -%}{% render 'font-stack', key: block.settings.title_font %}{%- endcapture -%}
      {%- capture block_subtitle_font -%}{% render 'font-stack', key: block.settings.subtitle_font %}{%- endcapture -%}
      <div class="trust-feat" {{ block.shopify_attributes }}>
        <span class="trust-feat__icon">{% render 'icon', name: block.settings.icon %}</span>
        <div>
          <h4 style="font-family:{{ block_title_font }}; font-size:{{ block.settings.title_size }}px;">{{ block.settings.title }}</h4>
          <p style="font-family:{{ block_subtitle_font }}; font-size:{{ block.settings.subtitle_size }}px;">{{ block.settings.subtitle }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust band",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon", "default": "droplets",
          "options": [
            { "value": "droplets", "label": "Waterproof (droplets)" },
            { "value": "gem", "label": "Premium (gem)" },
            { "value": "hand", "label": "Handmade (hand)" },
            { "value": "truck", "label": "Shipping (truck)" },
            { "value": "heart", "label": "Loved (heart)" },
            { "value": "star",  "label": "Reviewed (star)" }
          ]
        },
        { "type": "header", "content": "Title" },
        { "type": "text", "id": "title", "label": "Title", "default": "Fully waterproof" },
        { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "title_size", "label": "Title size", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 15 },

        { "type": "header", "content": "Subtitle" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Original biothane — rinse, ride home, dry." },
        { "type": "select", "id": "subtitle_font", "label": "Subtitle font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Sans (Hanken Grotesk)" },
            { "value": "display", "label": "Display (Friendship script)" },
            { "value": "accent", "label": "Accent (Farmhouse serif)" }
          ] },
        { "type": "range", "id": "subtitle_size", "label": "Subtitle size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 }
      ]
    }
  ],
  "presets": [{
    "name": "Trust band",
    "blocks": [
      { "type": "feature", "settings": { "icon": "droplets", "title": "Fully waterproof", "subtitle": "Original biothane — rinse, ride home, dry." } },
      { "type": "feature", "settings": { "icon": "gem", "title": "Solid brass hardware", "subtitle": "Built to outlast a thousand walks." } },
      { "type": "feature", "settings": { "icon": "hand", "title": "Made by hand", "subtitle": "Small batches, cut & riveted in-house." } },
      { "type": "feature", "settings": { "icon": "truck", "title": "Free shipping $60+", "subtitle": "1-year warranty on every piece." } }
    ]
  }]
}
{% endschema %}
