{%- comment -%}
  KYN — Video spotlight (full-width video with overlaid caption)
{%- endcomment -%}

{%- capture eyebrow_font -%}{% render 'font-stack', key: section.settings.eyebrow_font %}{%- endcapture -%}
{%- capture title_font -%}{% render 'font-stack', key: section.settings.title_font %}{%- endcapture -%}
{%- capture spark_font -%}{% render 'font-stack', key: section.settings.spark_font %}{%- endcapture -%}

<section id="video-spotlight-{{ section.id }}" class="section video-spotlight" style="background: {{ section.settings.bg }};">
  <div class="container">
    <div class="video-spotlight__frame">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, class: 'video-spotlight__video' }}
      {%- else -%}
        <div class="video-spotlight__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}</div>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
        <div class="video-spotlight__overlay">
          {%- if section.settings.eyebrow != blank -%}
            <span class="eyebrow eyebrow--on-dark">{{ section.settings.eyebrow | escape }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="h-display">
              {{ section.settings.title | escape }}
              {%- if section.settings.spark_word != blank -%}
                <span class="spark">{{ section.settings.spark_word | escape }}</span>
              {%- endif -%}
            </h2>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #video-spotlight-{{ section.id }} .eyebrow{
    font-family: {{ eyebrow_font }};
    font-size: {{ section.settings.eyebrow_size }}px;
  }
  #video-spotlight-{{ section.id }} .h-display{
    font-family: {{ title_font }};
    font-size: {{ section.settings.title_size }}px;
  }
  #video-spotlight-{{ section.id }} .h-display .spark{
    font-family: {{ spark_font }};
    font-size: {{ section.settings.spark_size }}px;
  }
  @media (max-width: 749px){
    #video-spotlight-{{ section.id }} .h-display{ font-size: {{ section.settings.title_size | times: 0.72 | round }}px; }
    #video-spotlight-{{ section.id }} .h-display .spark{ font-size: {{ section.settings.spark_size | times: 0.72 | round }}px; }
  }
</style>

{% schema %}
{
  "name": "Video spotlight",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#FFFDF8" },
    { "type": "video", "id": "video", "label": "Video" },

    { "type": "header", "content": "Eyebrow" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow" },
    { "type": "select", "id": "eyebrow_font", "label": "Eyebrow font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "eyebrow_size", "label": "Eyebrow size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Title" },
    { "type": "text",  "id": "title", "label": "Title" },
    { "type": "select", "id": "title_font", "label": "Title font", "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 24, "max": 72, "step": 2, "unit": "px", "default": 40 },
    { "type": "text",  "id": "spark_word", "label": "Spark word" },
    { "type": "select", "id": "spark_font", "label": "Spark word font", "default": "display",
      "options": [
        { "value": "sans", "label": "Sans (Hanken Grotesk)" },
        { "value": "display", "label": "Display (Friendship script)" },
        { "value": "accent", "label": "Accent (Farmhouse serif)" }
      ] },
    { "type": "range", "id": "spark_size", "label": "Spark word size", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 42 }
  ],
  "presets": [
    { "name": "Video spotlight" }
  ]
}
{% endschema %}
